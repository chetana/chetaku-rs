{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pre-commit-check.sh",
            "statusMessage": "Running cargo check before commit...",
            "timeout": 60
          }
        ]
      }
    ]
  }
}
